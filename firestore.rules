rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{uid} {
      // Any signed-in user can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Admin can read/write ALL user documents
      // We check the role directly in the token claim OR in the document
      allow read, write: if request.auth != null
        && request.auth.uid != uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Resources - fully public read, any signed-in user can write (for dev)
    match /resources/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Universities - fully public read, any signed-in user can write (for dev)
    match /universities/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Marketplace
    match /marketplace/{id} {
      allow read, write: if request.auth != null;
    }

    // Bids
    match /bids/{id} {
      allow read, write: if request.auth != null;
    }

    // Help Requests
    match /helpRequests/{id} {
      allow read, write: if request.auth != null;
    }
  }
}